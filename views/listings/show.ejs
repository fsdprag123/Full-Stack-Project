<div class="container mt-5 mb-5">

    <div class="card shadow-lg border-0">

        <!-- Event Image -->
        <img 
            src="<%= event.image.url %>" 
            class="card-img-top event-img"
            alt="<%= event.name %>">

        <div class="card-body p-4">
            <p class="text-muted mb-3">
                Owner: <strong><%= event.owner.username %></strong>
            </p>

            <!-- Title -->
            <h2 class="fw-bold mb-2"><%= event.name %></h2>
            <p class="text-muted mb-3">
                Theme: <strong><%= event.theme %></strong>
            </p>

            <hr>

            <!-- Event Info -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <p><strong>Date & Time:</strong><br>
                        <%= new Date(event.dateTime).toLocaleString("en-IN") %>
                    </p>
                    <p><strong>Venue:</strong><br>
                        <%= event.venue %>
                    </p>
                </div>

                <div class="col-md-6">
                    <p><strong>Organizer:</strong><br>
                        <%= event.organizer %>
                    </p>
                    <p><strong>Registration Fee:</strong><br>
                        ₹ <%= event.registrationFee %>
                    </p>
                </div>
            </div>

            <hr>

            <!-- Description -->
            <div class="mb-4">
                <h5 class="text-primary">Description</h5>
                <p><%= event.description %></p>
            </div>

            <!-- Prizes -->
            <div class="mb-4">
                <h5 class="text-primary">Prizes & Benefits</h5>
                <p><%= event.prizesAndBenefits %></p>
            </div>

            <!-- Contact Section -->
            <div class="mb-4">
                <h5 class="text-primary">Contact Information</h5>
                <p><strong>Phone:</strong> <%= event.contactNumber %></p>

                <a href="<%= event.whatsappLink %>" 
                   target="_blank" 
                   class="btn btn-success me-2">
                    Join WhatsApp
                </a>
            </div>

            <!-- Social Media -->
            <% if (event.socialMediaLinks && event.socialMediaLinks.length > 0) { %>
                <div class="mb-4">
                    <h5 class="text-primary">Follow Us</h5>
                    <% event.socialMediaLinks.forEach(link => { %>
                        <a href="<%= link %>" 
                           target="_blank" 
                           class="d-block text-decoration-none text-info">
                            <%= link %>
                        </a>
                    <% }) %>
                </div>
            <% } %>

            <hr>
                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-between align-items-center flex-wrap mt-4">

                    <!-- Left Side -->
                    <div>
                     <% if(!event.owner.equals(currUser._id)) { %>
                        <% if(!currUser.registerEvents.includes(event._id)) { %>
                            <a href="/events/<%= event._id %>/register" 
                            class="btn btn-primary">
                                Register Now
                            </a>
                        <% } else { %>

                            <button class="btn btn-success" disabled>
                                Already Registered
                            </button>

                        <% } %>   


                   <% } else { %>
                    <a href="/user/<%= event._id %>/registrations" 
                    class="btn btn-primary">
                        View Registrations
                    </a>

                   <% } %>
                    
                    </div>

                    <!-- Right Side -->
                    <div class="mt-2 mt-md-0">
                   <% if (event.owner.equals(currUser._id)) { %>

                        <form action="/events/<%= event._id %>/edit" method="GET" style="display:inline;">
                            <button class="btn btn-warning me-2">
                                ✏️ Edit
                            </button>
                        </form>

                        <form action="/events/<%= event._id %>?_method=DELETE" 
                            method="POST" 
                            class="d-inline">

                            <button class="btn btn-danger"
                                onclick="return confirm('Are you sure you want to delete this event?')">
                                🗑 Delete
                            </button>
                        </form>

                     <% } %>
                   

                    </div>

</div>

        </div>
    </div>
</div>
