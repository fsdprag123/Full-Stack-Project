<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #667eea, #764ba2);
            min-height: 100vh;
        }

        .profile-card {
            border-radius: 20px;
            background: #fff;
        }

        .profile-img {
            width: 110px;
            height: 110px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 38px;
            font-weight: bold;
            color: #fff;
            background: linear-gradient(135deg, #36d1dc, #5b86e5);
            margin: auto;
        }

        .label {
            font-weight: 600;
            color: #6c757d;
        }

        .value {
            font-weight: 500;
        }

        .btn-custom {
            border-radius: 10px;
            padding: 8px 16px;
        }

        .event-box {
            border-radius: 12px;
            padding: 15px;
            background: #f8f9fa;
            transition: 0.3s;
        }

        .event-box:hover {
            background: #e9ecef;
            transform: translateY(-2px);
        }
    </style>
</head>

<body>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">

    <div class="card profile-card shadow-lg p-4 w-100" style="max-width: 850px;">
        <div class="row align-items-center">

            <!-- Profile -->
            <div class="col-md-4 text-center mb-4 mb-md-0">
                <div class="profile-img mb-3">
                    <%= user.name?.charAt(0).toUpperCase() || 'U' %>
                </div>

                <h4 class="fw-bold"><%= user.name || "User" %></h4>
                <p class="text-muted">Student</p>
            </div>

            <!-- Details -->
            <div class="col-md-8">
                <h3 class="mb-4 text-primary">Profile Details</h3>

                <div class="row mb-2">
                    <div class="col-sm-4 label">Email</div>
                    <div class="col-sm-8 value"><%= user.email || 'N/A' %></div>
                </div>

                <div class="row mb-2">
                    <div class="col-sm-4 label">Roll Number</div>
                    <div class="col-sm-8 value"><%= user.username || 'N/A' %></div>
                </div>

                <div class="row mb-2">
                    <div class="col-sm-4 label">Branch</div>
                    <div class="col-sm-8 value"><%= user.branch || 'N/A' %></div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4 label">Year</div>
                    <div class="col-sm-8 value">
                        <%= user.year ? user.year + " Year" : "N/A" %>
                    </div>
                </div>

                <hr>

                <!-- Events Section -->
                <h5 class="mb-3">🎯 Your Activities</h5>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <a href="/user/createdevents" class="text-decoration-none text-dark">
                            <div class="event-box shadow-sm">
                                <h6 class="mb-1">📌 Created Events</h6>
                                <small>Manage events you created</small>
                            </div>
                        </a>
                    </div>

                    <div class="col-md-6">
                        <a href="/user/registerevents" class="text-decoration-none text-dark">
                            <div class="event-box shadow-sm">
                                <h6 class="mb-1">✅ Registered Events</h6>
                                <small>View your registrations</small>
                            </div>
                        </a>
                    </div>
                </div>

                <hr>

                <!-- Buttons -->
                <div class="d-flex gap-2">

                    <a href="/events" class="btn btn-light btn-custom">
                        ⬅ Back
                    </a>
                </div>

            </div>

        </div>
    </div>

</div>

</body>
</html>